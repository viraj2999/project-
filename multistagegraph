#include <stdio.h>
#define INF 999

int main() {
    int cost[4][4] = {
        {INF, 2, 1, 3},
        {INF, INF, INF, 6},
        {INF, INF, INF, 2},
        {INF, INF, INF, INF}
    };
    int dist[4], i, j, n = 4;

    dist[n-1] = 0;

    for(i = n-2; i >= 0; i--) {
        dist[i] = INF;
        for(j = i+1; j < n; j++) {
            if(cost[i][j] != INF && cost[i][j] + dist[j] < dist[i])
                dist[i] = cost[i][j] + dist[j];
        }
    }

    printf("Minimum cost: %d", dist[0]);
    return 0;
}
