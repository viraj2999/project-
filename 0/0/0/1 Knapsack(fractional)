#include <stdio.h>

int max(int a, int b){ return a>b?a:b; }

int main() {
    int wt[3]={1,2,3}, val[3]={10,15,40};
    int W=5, i, w, n=3;
    int dp[4][6]={0};

    for(i=1;i<=n;i++)
        for(w=1;w<=W;w++)
            if(wt[i-1]<=w)
                dp[i][w]=max(val[i-1]+dp[i-1][w-wt[i-1]],dp[i-1][w]);
            else
                dp[i][w]=dp[i-1][w];

    printf("Max value: %d", dp[n][W]);
}
