#include <stdio.h>
#define INF 999

int main() {
    int n=4, e=4;
    int u[]={0,0,1,2}, v[]={1,2,2,3}, w[]={1,4,2,3};
    int dist[4]={0,INF,INF,INF}, i,j;

    for(i=1;i<n;i++)
        for(j=0;j<e;j++)
            if(dist[u[j]]+w[j] < dist[v[j]])
                dist[v[j]] = dist[u[j]]+w[j];

    printf("Distances:\n");
    for(i=0;i<n;i++)
        printf("%d ",dist[i]);
}
