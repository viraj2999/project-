#include <stdio.h>

int main() {
    int a[3][3] = {{0,1,0},{0,0,1},{1,0,0}};
    int i,j,k,n=3;

    for(k=0;k<n;k++)
        for(i=0;i<n;i++)
            for(j=0;j<n;j++)
                a[i][j] = a[i][j] || (a[i][k] && a[k][j]);

    printf("Transitive closure:\n");
    for(i=0;i<n;i++){
        for(j=0;j<n;j++)
            printf("%d ",a[i][j]);
        printf("\n");
    }
}
