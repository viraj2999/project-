#include <stdio.h>
#define INF 999

int main() {
    int d[3][3] = {{0,5,INF},{INF,0,3},{2,INF,0}};
    int i,j,k,n=3;

    for(k=0;k<n;k++)
        for(i=0;i<n;i++)
            for(j=0;j<n;j++)
                if(d[i][j] > d[i][k] + d[k][j])
                    d[i][j] = d[i][k] + d[k][j];

    printf("Shortest paths:\n");
    for(i=0;i<n;i++){
        for(j=0;j<n;j++)
            printf("%d ",d[i][j]);
        printf("\n");
    }
}
